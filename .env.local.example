# Copy this file to .env.local and fill in real values.
# .env.local is gitignored so secrets stay off GitHub.

# Get from https://aistudio.google.com -> "Get API key"
GEMINI_API_KEY=your_gemini_key_here

# Web app URL from your Google Sheet's Apps Script deployment
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXX/exec
